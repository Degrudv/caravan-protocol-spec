{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Degrudv/caravan-protocol-spec/main/schemas/purchase-intent.schema.json",
  "title": "PurchaseIntent",
  "description": "Buyer-side intent; sealed, visible to the TEE matcher only (§5.1). Never shown to other buyers or to suppliers. Merkle leaf = H(intent); root committed on-chain at window open/close.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent_id",
    "agent_did",
    "principal_id",
    "sku_id",
    "qty",
    "price_ceiling",
    "substitution_policy",
    "duration",
    "expiry",
    "window_id",
    "delivery_constraints",
    "funds_preauth",
    "agent_sig"
  ],
  "properties": {
    "intent_id": {
      "type": "string",
      "format": "uuid"
    },
    "agent_did": {
      "type": "string",
      "pattern": "^did:[a-zA-Z0-9]+:[a-zA-Z0-9._:%-]+$"
    },
    "principal_id": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$",
      "description": "keccak256 hash of the principal_id (hashed for the matcher). The raw principal_id is never carried on a sealed intent."
    },
    "sku_id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+(\\.[A-Z0-9]+)*$"
    },
    "qty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 1 },
        "max": { "type": "integer", "minimum": 1 }
      }
    },
    "price_ceiling": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "USDC 6-decimal base units, string-encoded integer. Clearing above ceiling is an automatic, never-penalized CEILING_MISS exit (§5.2)."
    },
    "substitution_policy": {
      "description": "\"none\", or an explicit allow-list of substitute spec_hashes. Silent substitution is impossible by construction (§5.3).",
      "oneOf": [
        { "const": "none" },
        {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{64}$"
          }
        }
      ]
    },
    "duration": {
      "type": "string",
      "enum": ["window", "standing_7d", "standing_30d", "recurring_monthly"]
    },
    "expiry": {
      "type": "string",
      "format": "date-time"
    },
    "window_id": {
      "type": "string",
      "minLength": 1
    },
    "delivery_constraints": {
      "type": "object",
      "description": "Deliberately open-ended (per §5.1 `{...}`), unlike every other object in this schema.",
      "properties": {
        "jurisdiction": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "latest_delivery": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "funds_preauth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token", "amount", "escrow_permit_sig"],
      "description": "Permit2-style pre-authorization; funds move into PoolEscrow at join (§5.3).",
      "properties": {
        "token": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$",
          "description": "Settlement asset contract address (USDC; params.settlementAsset)."
        },
        "amount": {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "USDC 6-decimal base units, string-encoded integer."
        },
        "escrow_permit_sig": {
          "type": "object",
          "additionalProperties": false,
          "required": ["signature", "signer_address"],
          "properties": {
            "signature": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]+$"
            },
            "signer_address": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{40}$"
            },
            "nonce": {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            "deadline": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "agent_sig": {
      "$ref": "#/$defs/Eip712Signature"
    }
  },
  "$defs": {
    "Eip712Signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signature", "signer_address"],
      "properties": {
        "signature": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]+$"
        },
        "signer_address": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        },
        "domain_hash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
