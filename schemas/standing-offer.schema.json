{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Degrudv/caravan-protocol-spec/main/schemas/standing-offer.schema.json",
  "title": "StandingOffer",
  "description": "Supplier-side offer; signed, executable only by PoolEscrow (§5.1).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "offer_id",
    "supplier_principal_id",
    "sku_id",
    "spec_hash",
    "tier_curve",
    "reference_price_qty1",
    "reference_bond",
    "tier_fallback_rule",
    "capacity",
    "expiry",
    "delivery_deadline",
    "vfm_params",
    "supplier_sig"
  ],
  "properties": {
    "offer_id": {
      "type": "string",
      "format": "uuid"
    },
    "supplier_principal_id": {
      "type": "string",
      "format": "uuid"
    },
    "sku_id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+(\\.[A-Z0-9]+)*$"
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "tier_curve": {
      "type": "array",
      "minItems": 1,
      "description": "Monotonically non-increasing unit_price as min_qty increases.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["min_qty", "unit_price"],
        "properties": {
          "min_qty": {
            "type": "integer",
            "minimum": 1
          },
          "unit_price": {
            "type": "string",
            "pattern": "^[0-9]+$",
            "description": "USDC 6-decimal base units, string-encoded integer."
          }
        }
      }
    },
    "reference_price_qty1": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "BONDED qty-1 reference price, USDC 6-decimal base units, string-encoded integer (§6.3)."
    },
    "reference_bond": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Bond amount slashable if the reference price is proven falsifiable, USDC 6-decimal base units, string-encoded integer (§6.3)."
    },
    "tier_fallback_rule": {
      "type": "string",
      "enum": ["next_valid_tier", "replacement_window", "cancel_refund"],
      "description": "Pre-committed at signing; immutable after pool formation (§5.3)."
    },
    "capacity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 1 }
      }
    },
    "expiry": {
      "type": "string",
      "format": "date-time"
    },
    "delivery_deadline": {
      "type": "string",
      "pattern": "^P(?!$)(\\d+Y)?(\\d+M)?(\\d+D)?(T(?=\\d)(\\d+H)?(\\d+M)?(\\d+S)?)?$",
      "description": "ISO-8601 duration; missing it triggers automatic full refund + supplier reputation attestation."
    },
    "vfm_params": {
      "type": "object",
      "required": ["class"],
      "properties": {
        "class": {
          "type": "string",
          "enum": ["A", "B", "C", "D"]
        }
      },
      "additionalProperties": true,
      "description": "VFM class-specific predicate parameters (see vfm/predicates.md and params.vfm). Deliberately open-ended: shape differs per class, unlike every other object in this schema."
    },
    "supplier_sig": {
      "$ref": "#/$defs/Eip712Signature"
    }
  },
  "$defs": {
    "Eip712Signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signature", "signer_address"],
      "properties": {
        "signature": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]+$"
        },
        "signer_address": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        },
        "domain_hash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
